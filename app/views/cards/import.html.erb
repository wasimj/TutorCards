<div class="panel">
  <h2>Import cards from CSV</h2>
  <p style="font-size: 0.88rem; color: #8b8ba0; line-height: 1.55; margin-bottom: 1rem;">
    Upload a CSV with columns <code>name,photo</code>. Optionally upload the photo files in the same form
    (drag-select multiple). Existing cards are kept; new rows are added with Box 1.
  </p>

  <%= form_with url: import_cards_path, method: :post, multipart: true, local: true do |f| %>
    <div style="display: flex; flex-direction: column; gap: 0.9rem;">
      <label style="display: flex; flex-direction: column; gap: 0.3rem;">
        <span style="font-size: 0.75rem; color: #6b6b85; text-transform: uppercase; letter-spacing: 0.08em;">CSV file</span>
        <%= f.file_field :csv, accept: ".csv,text/csv", required: true %>
      </label>
      <label style="display: flex; flex-direction: column; gap: 0.3rem;">
        <span style="font-size: 0.75rem; color: #6b6b85; text-transform: uppercase; letter-spacing: 0.08em;">Photos (optional, multi-select)</span>
        <%= f.file_field :photos, multiple: true, accept: "image/*" %>
      </label>
      <div style="display: flex; gap: 0.6rem;">
        <%= f.submit "Import", class: "btn" %>
        <%= link_to "Cancel", root_path, class: "btn secondary" %>
      </div>
    </div>
  <% end %>
</div>

<div class="panel">
  <h2>Sample CSV</h2>
  <p style="font-size: 0.85rem; color: #8b8ba0; line-height: 1.55; margin-bottom: 0.6rem;">
    Bundled sample lives at <code>db/sample/students.csv</code> with matching photos in
    <code>db/sample/photos/</code>. After running <code>bin/rails db:seed</code> the
    sample group is loaded automatically.
  </p>
</div>
