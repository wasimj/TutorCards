<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Tutor Group Cards" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app %>
  </head>
  <body>
    <header class="app-header">
      <div class="logo">Tutor<span>Cards</span></div>
      <nav class="nav">
        <%= link_to "Dashboard", root_path %>
        <%= link_to "Study", study_path %>
        <%= link_to "Cards", cards_path %>
        <%= link_to "Import", import_cards_path %>
        <a href="http://192.168.122.242:8080/" target="_blank">← projects.vm</a>
      </nav>
    </header>
    <main class="container">
      <% if notice %><div class="flash"><%= notice %></div><% end %>
      <% if alert %><div class="flash alert"><%= alert %></div><% end %>
      <%= yield %>
    </main>
  </body>
</html>
